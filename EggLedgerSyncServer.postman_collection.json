    {
      "name": "User",
      "item": [
        {
          "name": "Delete User Account",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{base_url}}/user",
              "host": ["{{base_url}}"],
              "path": ["user"]
            },
            "description": "WARNING: Permanently deletes the authenticated user row and all associated blobs via CASCADE. This cannot be undone. After this call, the session token is also invalid."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));",
                  "if (pm.response.code === 204) {",
                  "    pm.collectionVariables.set('token', '');",
                  "    console.log('Token cleared — user account deleted');",
                  "}"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "header": [],
              "body": ""
            }
          ]
        }
      ]
    },
    {
      "name": "Verification",
      "item": [
        {
          "name": "Verify Binary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/verify",
              "host": ["{{base_url}}"],
              "path": ["verify"]
            },
            "description": "Returns the SHA-256 hash, version string, and build date of the running binary. In local dev builds these will be `unknown`/`dev` unless -ldflags were passed."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Has sha256 field', () => pm.expect(body.sha256).to.be.a('string').and.not.empty);",
                  "pm.test('Has version field', () => pm.expect(body.version).to.be.a('string').and.not.empty);",
                  "pm.test('Has built field', () => pm.expect(body.built).to.be.a('string').and.not.empty);"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 OK (production build)",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"sha256\":\"a1b2c3...\",\"version\":\"v1.0.0\",\"built\":\"2026-04-25T00:00:00Z\"}"
            },
            {
              "name": "200 OK (local dev build)",
              "status": "OK",
              "code": 200,
              "header": [{"key": "Content-Type", "value": "application/json"}],
              "body": "{\"sha256\":\"unknown\",\"version\":\"dev\",\"built\":\"unknown\"}"
            }
          ]
        }
      ]
    },
    {
